# Active Caddyfile for the default Hermes stack.
# Mounted automatically by lobster-cage/docker-compose.yml.
# OpenClaw keeps its own override in caddy/Caddyfile.openclaw.

:{$OPENCLAW_PORT:18789} {
    tls /certs/cert.pem /certs/key.pem

    route {
        # Basic Auth for HTTP only (not WebSocket)
        @not_websocket {
            not header Connection *Upgrade*
        }
        basic_auth @not_websocket {
            {$CADDY_AUTH_USER:admin} {$CADDY_AUTH_HASH}
        }

        # Reverse proxy to Hermes API Server (port 8642)
        reverse_proxy http://hermes:8642 {
            header_up -Authorization
            header_up X-Real-IP {remote_host}
        }
    }
}

# Browserless debugger UI (live view of agent browser sessions)
:3005 {
    tls /certs/cert.pem /certs/key.pem

    # Protect HTTP requests with basic auth.
    # WebSocket connections (live screen stream) bypass auth because
    # browsers do not reliably send basic-auth headers on WS upgrades.
    @not_websocket {
        not header Connection *Upgrade*
    }
    basic_auth @not_websocket {
        {$CADDY_AUTH_USER:admin} {$CADDY_AUTH_HASH}
    }

    route {
        # Serve the patched router locally so the debugger keeps the same
        # session filtering behavior as the OpenClaw variant.
        @debugger_router path /debugger/router.js
        handle @debugger_router {
            rewrite * /router.js
            root * /srv/browserless-debugger
            file_server
        }

        handle {
            reverse_proxy http://browserless:3000 {
                header_up Authorization "Bearer {$BROWSERLESS_TOKEN}"
                header_up Host {host}
            }
        }
    }
}


# ClawRoute dashboard
:{$CLAWROUTE_PORT:18790} {
    tls /certs/cert.pem /certs/key.pem

    basic_auth {
        {$CADDY_AUTH_USER:admin} {$CADDY_AUTH_HASH}
    }

    reverse_proxy http://clawroute:18790
}

# Hermes Dashboard (config, sessions, analytics, cron, skills)
:9119 {
    tls /certs/cert.pem /certs/key.pem

    # API/WS routes — skip basic_auth; Hermes validates its own Bearer token
    @internal path /api/* /ws/*
    handle @internal {
        reverse_proxy http://hermes:9119
    }

    # Everything else — require Caddy basic auth
    handle {
        basic_auth {
            {$CADDY_AUTH_USER:admin} {$CADDY_AUTH_HASH}
        }
        reverse_proxy http://hermes:9119
    }
}

# Hermes app (agent-created web app)
:8787 {
    tls /certs/cert.pem /certs/key.pem

    basic_auth {
        {$CADDY_AUTH_USER:admin} {$CADDY_AUTH_HASH}
    }

    reverse_proxy http://hermes:8787
}

# Hermes app on port 3199
:3199 {
    tls /certs/cert.pem /certs/key.pem

    basic_auth {
        {$CADDY_AUTH_USER:admin} {$CADDY_AUTH_HASH}
    }

    reverse_proxy http://hermes:3199
}
