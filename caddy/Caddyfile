:{$OPENCLAW_PORT:18789} {
    tls /certs/cert.pem /certs/key.pem

    route {
        # Basic Auth for HTTP only (not WebSocket)
        # WebSocket auth is handled by OpenClaw's device-token system
        @not_websocket {
            not header Connection *Upgrade*
        }
        basic_auth @not_websocket {
            {$CADDY_AUTH_USER:admin} {$CADDY_AUTH_HASH}
        }

        # Bookmark /go to auto-authenticate on every browser session
        redir /go /#token={$OPENCLAW_GATEWAY_TOKEN} 302

        # Reverse proxy to OpenClaw
        reverse_proxy http://openclaw:18789 {
            header_up -Authorization
            header_up X-Real-IP {remote_host}
        }
    }
}

# ClawRoute dashboard
:{$CLAWROUTE_PORT:18790} {
    tls /certs/cert.pem /certs/key.pem

    basic_auth {
        {$CADDY_AUTH_USER:admin} {$CADDY_AUTH_HASH}
    }

    reverse_proxy http://clawroute:18790
}
