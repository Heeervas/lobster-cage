# Lobster Cage – Environment Variables
# Copy this file to .env and fill in your values.

# ─── AI Model API Keys ───────────────────────────────────────────
# At least one model provider is required for the agent to function.

# GitHub Copilot Token (get from: https://github.com/settings/tokens)
COPILOT_GITHUB_TOKEN=

# Google Gemini API Key (get from: https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# NVIDIA API Key (get from: https://build.nvidia.com/)
NVIDIA_API_KEY=

# OpenAI API Key (get from: https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# OpenRouter API Key (get from: https://openrouter.ai/keys)
# Access 200+ models (Claude, Llama, Mistral, etc.) through a single API
OPENROUTER_API_KEY=

# ─── Telegram Bot (optional) ─────────────────────────────────────
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# ─── Web UI Access ───────────────────────────────────────────────
# Caddy Basic Auth credentials for the web interface.
# Username for basic auth (default: admin)
CADDY_AUTH_USER=admin
# Password for basic auth — will be bcrypt-hashed by setup.sh
CADDY_AUTH_PASSWORD=change-me-please

# ─── Network / Host ──────────────────────────────────────────────
# Your machine's LAN IP (used for Caddy TLS cert and allowed origins)
LAN_IP=192.168.1.100

# Port for the web UI (default: 18789)
OPENCLAW_PORT=18789

# OpenClaw gateway token (shared secret for device pairing)
OPENCLAW_GATEWAY_TOKEN=change-me-to-a-random-string

# ─── Workspace Path (optional) ───────────────────────────────────
# Path on the host that the agent uses as its workspace.
# Default: ./workspace (created automatically)
# OPENCLAW_WORKSPACE_PATH=/path/to/your/workspace

# ─── TLS Skip Verification (optional) ───────────────────────────
# Comma-separated list of hosts with self-signed TLS certs (e.g. local Nextcloud)
# TLS_SKIP_VERIFY_HOSTS=192.168.1.100

# ─── Nextcloud CalDAV (optional) ─────────────────────────────────
# For calendar integration. See docker-compose.override.example.yml
# NC_CALDAV_URL=https://192.168.1.100/remote.php/dav
# NC_CALDAV_USER=your-user
# NC_CALDAV_APP_PASSWORD=your-app-password

# ─── Home Assistant (optional) ───────────────────────────────────
# For smart home integration. See docker-compose.override.example.yml
# HA_URL=http://192.168.1.100:8123
# HA_TOKEN=your-long-lived-access-token

# ─── Docker Network (optional) ───────────────────────────────────
# Change if 172.28.0.0/24 conflicts with your LAN, VPN, or another Docker network.
# If changed, also update the Allow line in outbound-proxy/tinyproxy.conf to match.
# OPENCLAW_SUBNET=172.28.0.0/24
# OPENCLAW_DNS_IP=172.28.0.253
